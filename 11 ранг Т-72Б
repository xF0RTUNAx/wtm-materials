    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-app.js";
        import { getDatabase, ref, runTransaction, onValue } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-database.js";

      
        const firebaseConfig = {
            apiKey: "AIzaSyBKH58hpUmUb0fJ1PCos8ZO9sJ1deMpJ8U",
            authDomain: "wtm-fortuna.firebaseapp.com",
            databaseURL: "https://wtm-fortuna-default-rtdb.europe-west1.firebasedatabase.app",
            projectId: "wtm-fortuna",
            storageBucket: "wtm-fortuna.firebasestorage.app",
            messagingSenderId: "438964530574",
            appId: "1:438964530574:web:42211e640b89c7d928c8df"
        };
        
        // УНИКАЛЬНЫЙ ID ДЛЯ ЭТОГО ТАНКА
        const TANK_ID = 't72_b'; 

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app, firebaseConfig.databaseURL);
        const dbRef = ref(db, 'ratings/' + TANK_ID);

        const stars = document.querySelectorAll('.star');
        const msg = document.getElementById('user-message');
        const avgDisplay = document.getElementById('avg-score');
        const countDisplay = document.getElementById('vote-count');
        const LOCAL_STORAGE_KEY = 'voted_' + TANK_ID;

        stars.forEach((star, index) => {
            star.addEventListener('mouseover', () => highlightStars(index + 1));
            star.addEventListener('mouseleave', () => resetStars());
            star.addEventListener('click', () => submitVote(index + 1));
        });

        function highlightStars(count) {
            stars.forEach((s, i) => {
                if (i < count) s.classList.add('hovered');
                else s.classList.remove('hovered');
            });
        }

        function resetStars() {
            stars.forEach(s => s.classList.remove('hovered'));
        }

        function submitVote(rating) {
            if (localStorage.getItem(LOCAL_STORAGE_KEY)) {
                msg.textContent = "Вы уже голосовали! Спасибо.";
                msg.style.color = "#ff5555";
                return;
            }

            msg.textContent = "Отправка...";
            
            runTransaction(dbRef, (currentData) => {
                if (currentData === null) {
                    return { sum: rating, count: 1 };
                } else {
                    return {
                        sum: (currentData.sum || 0) + rating,
                        count: (currentData.count || 0) + 1
                    };
                }
            }).then(() => {
                msg.textContent = "Голос принят! Спасибо.";
                msg.style.color = "#55ff55";
                localStorage.setItem(LOCAL_STORAGE_KEY, 'true');
                stars.forEach((s, i) => {
                    if (i < rating) s.classList.add('active');
                });
            }).catch((err) => {
                console.error("Firebase Error:", err);
                msg.textContent = "Ошибка доступа.";
                msg.style.color = "red";
            });
        }

        onValue(dbRef, (snapshot) => {
            const data = snapshot.val();
            if (data && data.count > 0) {
                const average = (data.sum / data.count).toFixed(1);
                avgDisplay.textContent = average;
                countDisplay.textContent = data.count;
            } else {
                avgDisplay.textContent = "0.0";
                countDisplay.textContent = "0";
            }
        }, (error) => {
            console.error("Firebase Read Error:", error);
            avgDisplay.textContent = "ERR"; 
            msg.textContent = "Ошибка базы.";
            msg.style.color = "red";
        });
    </script>
