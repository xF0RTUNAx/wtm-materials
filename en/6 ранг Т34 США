<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>WTM: T34 Review</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: url('https://static.wtmobile.com/upload/fileman/images/wallpapers/26_03_tropicraid/1080x2340_wtm_tropic_raid_4c76c6385da2dfd1be8c9eb1a7e4ff52.jpg') no-repeat center center fixed;
            background-size: cover;
            color: white;
            margin: 0;
            padding: 20px;
            line-height: 1.6;
            animation: fadeIn 1s ease-in-out;
            overflow-x: hidden;
            position: relative;
        }
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: -1;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 30px;
            background: rgba(20, 20, 20, 0.85); 
            border-radius: 25px;
            box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            overflow: hidden;
        }
        h1, h2, h3 {
            text-shadow: 0 2px 4px black;
            position: relative;
        }
        h1, h2 { color: #ffc000; }
        h3 { color: #ffffff; }
        
        h1::before, h2::before {
            content: "";
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 50px;
            height: 3px;
            background: linear-gradient(to right, #0056b3, #3388d1);
            border-radius: 2px;
        }
        
        /* --- CONTENT STYLES --- */
        .tank-image {
            width: 100%;
            height: auto;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            margin-bottom: 20px;
            border: 1px solid rgba(255,255,255,0.2);
        }
        .content-section {
            background: rgba(255, 255, 255, 0.05); 
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
        }
        .content-section p { margin-bottom: 10px; }
        .content-section ul { margin-top: 5px; margin-bottom: 15px; padding-left: 20px; }
        .content-section li { margin-bottom: 8px; }
        
        /* --- BUTTONS --- */
        .back-button {
            margin-top: 30px;
            display: block;
            text-align: center;
            font-size: 1.1em;
            font-weight: bold;
            color: white;
            background: #0056b3;
            padding: 15px 30px;
            border-radius: 10px;
            text-decoration: none;
            border: none;
            cursor: pointer;
            width: 100%;
            max-width: 300px;
            margin-left: auto;
            margin-right: auto;
            transition: background-color 0.3s ease;
        }
        .back-button:hover { background-color: #004494; }

        /* --- COMMENTS SECTION --- */
        .comments-wrapper {
            margin-top: 40px; 
            margin-bottom: 20px;
            background: rgba(0, 0, 0, 0.3);
            padding: 15px;
            border-radius: 15px;
            max-width: 100%;
            box-sizing: border-box;
            overflow-x: hidden;
        }

        footer {
            text-align: center;
            font-size: 0.9em;
            color: #ccc;
            margin-top: 30px;
            padding: 15px;
        }

        /* --- FIREBASE RATING STYLES --- */
        .firebase-rating-box {
            background: rgba(0, 0, 0, 0.4);
            padding: 20px;
            border-radius: 15px;
            margin-top: 20px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .interactive-stars {
            font-size: 2.5em;
            cursor: pointer;
            display: inline-block;
            margin-top: 10px;
            user-select: none;
            white-space: nowrap; 
        }
        .star {
            color: gray;
            transition: color 0.2s, transform 0.2s;
            display: inline-block;
        }
        .star.active, .star.hovered {
            color: #ffcc00;
            text-shadow: 0 0 10px rgba(255, 204, 0, 0.6);
        }
        .star:active { transform: scale(0.9); }

        /* --- RESPONSIVENESS (MOBILE) --- */
        @media (max-width: 768px) {
            .container { padding: 15px; }
            .content-section { background: rgba(255, 255, 255, 0.08); }
            .interactive-stars { font-size: 1.8em; }
            .comments-wrapper { padding: 5px; } 
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>6 rank T34</h1>
        <img src="https://github.com/xF0RTUNAx/wtm-materials/blob/pics/t34/t34_main.webp?raw=true" alt="T34 Tank" class="tank-image">
        
        <div class="content-section">
            <h2>Historical Background</h2>
            <p>The T34 is an American heavy tank, the development of which began as a response to the appearance of German heavy vehicles in Europe: Tiger II, Panther, and Jagdtiger. The US needed a vehicle capable of confidently penetrating their frontal armor while withstanding fire from powerful 88–128 mm guns. February 1944 marked the start of work on the project. By 1945, the first prototypes were assembled.</p>
            <p>The tank had a mass of about 70 tons, serious frontal protection, and a powerful gun, but the war ended before the T34 was brought to mass production.</p>
            <p>Today, the T34 exists only in the form of a few prototypes that were used for testing.</p>
            <img src="https://github.com/xF0RTUNAx/wtm-materials/blob/pics/t34/t34_historic.jpeg?raw=true" alt="Historical T34" class="tank-image" loading="lazy">
        </div>

        <div class="content-section">
            <h2>Brief Overview</h2>
            <h3>Maneuverability</h3>
            
            <p><strong>Pros:</strong></p>
            <ul>
                <li>Decent turret traverse and good vertical guidance angles (gun depression).</li>
                <li>Handling is acceptable for a heavy tank.</li>
            </ul>

            <p><strong>Cons:</strong></p>
            <ul>
                <li>Low speed, the tank takes a long time to accelerate.</li>
                <li>Weak hull traverse on the spot — light tanks (LTs) can easily circle it.</li>
                <li>It is almost impossible to be the first to take an important position.</li>
            </ul>
        </div>

        <div class="content-section">
            <h3>Armor and Survivability</h3>
            <p>The <strong>turret</strong> is the main advantage of the T34. The turret front is thick, often resulting in "non-penetration" and "hit". It takes hits perfectly, except for the large commander's cupola — this is a weak spot. Also vulnerable is the narrow strip above the gun, especially against APHE shells. Sometimes rare penetrations into the gun mantlet are possible due to technological cutouts.</p>
            <p><strong>Hull:</strong> the front is strong, but has two obvious weak spots: the machine gun port and the lower glacis plate (LFP), which is confidently penetrated by the Tiger II. Against some opponents, for example, the AMX Foch, you can catch ricochets — their shells tend to deflect aside.</p>
        </div>

        <div class="content-section">
            <h3>Armament</h3>
            <p>The T34 is equipped with a 120 mm T53 gun.</p>
            
            <p><strong>Pros:</strong></p>
            <ul>
                <li>Excellent penetration.</li>
                <li>High damage per hit.</li>
                <li>Very good gun depression angles.</li>
                <li>Fast aiming and comfortable shooting.</li>
            </ul>

            <p><strong>Cons:</strong></p>
            <ul>
                <li>Large muzzle brake — often catches hits, causing the gun to take critical damage.</li>
                <li>Long reload time (about 20 seconds) — inferior to the Tiger II with its ~9.7 s.</li>
            </ul>
            
            <p>There are also three M2 Browning machine guns, which allow you to knock out LT modules and attack aerial targets. However, there is often not enough time to kill important LT crew members with machine guns.</p>
            <img src="https://github.com/xF0RTUNAx/wtm-materials/blob/pics/t34/t34_weapon.webp?raw=true" alt="T34 Armament" class="tank-image" loading="lazy" style="margin-top: 15px;">
        </div>

        <div class="content-section" style="border-left: 5px solid #ffcc00;">
            <h3>Conclusions and Comments</h3>
            <p>Gameplay on the T34 is built around its strong turret and excellent gun depression angles. Look for uneven terrain, hide the vulnerable hull with the LFP, and play "hull-down" (from the turret), dealing devastating damage with the 120 mm gun.</p>
            <p>Due to poor mobility, long reload time, and slow hull traverse, getting into close combat is extremely dangerous. Light tanks can easily circle you, and the machine guns will not always save the situation. Keep a medium distance and act as powerful fire support.</p>

            <div class="firebase-rating-box" id="rating-container">
                <div class="rating-header">
                    Community Rating: <span id="avg-score" style="color: #ffcc00; font-weight: bold; font-size: 1.2em;">--</span> 
                    <span style="font-size: 0.8em; opacity: 0.7; margin-left: 5px;">(Votes: <span id="vote-count">0</span>)</span>
                </div>
                
                <div class="interactive-stars" id="star-wrapper">
                    <span class="star" data-value="1">★</span>
                    <span class="star" data-value="2">★</span>
                    <span class="star" data-value="3">★</span>
                    <span class="star" data-value="4">★</span>
                    <span class="star" data-value="5">★</span>
                </div>
                <div id="user-message" style="margin-top: 10px; font-size: 0.9em; min-height: 24px;">Tap to rate</div>
            </div>
        </div>

        <button class="back-button" onclick="window.location.href = 'index.html'">
            ← Back to main page
        </button>

        <div class="comments-wrapper">
             <script async src="https://telegram.org/js/telegram-widget.js?23&lang=en" 
                data-telegram-discussion="fortunawtm_comments/49" 
                data-comments-limit="5" 
                data-colorful="1" 
                data-dark="1">
            </script>
        </div>

        <footer>
            <p>Made by Nikita. Last updated 04/16/2026. If you find errors or have suggestions - message @fortunawtm.</p>
        </footer>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-app.js";
        import { getDatabase, ref, runTransaction, onValue } from "https://www.gstatic.com/firebasejs/9.22.0/firebase-database.js";

        const firebaseConfig = {
            apiKey: "AIzaSyBKH58hpUmUb0fJ1PCos8ZO9sJ1deMpJ8U",
            authDomain: "wtm-fortuna.firebaseapp.com",
            databaseURL: "https://wtm-fortuna-default-rtdb.europe-west1.firebasedatabase.app",
            projectId: "wtm-fortuna",
            storageBucket: "wtm-fortuna.firebasestorage.app",
            messagingSenderId: "438964530574",
            appId: "1:438964530574:web:42211e640b89c7d928c8df"
        };
        
        // UNIQUE ID FOR THIS TANK
        const TANK_ID = 't34_heavy'; 

        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app, firebaseConfig.databaseURL);
        const dbRef = ref(db, 'ratings/' + TANK_ID);

        const stars = document.querySelectorAll('.star');
        const msg = document.getElementById('user-message');
        const avgDisplay = document.getElementById('avg-score');
        const countDisplay = document.getElementById('vote-count');
        const LOCAL_STORAGE_KEY = 'voted_' + TANK_ID;

        stars.forEach((star, index) => {
            star.addEventListener('mouseover', () => highlightStars(index + 1));
            star.addEventListener('mouseleave', () => resetStars());
            star.addEventListener('click', () => submitVote(index + 1));
        });

        function highlightStars(count) {
            stars.forEach((s, i) => {
                if (i < count) s.classList.add('hovered');
                else s.classList.remove('hovered');
            });
        }

        function resetStars() {
            stars.forEach(s => s.classList.remove('hovered'));
        }

        function submitVote(rating) {
            if (localStorage.getItem(LOCAL_STORAGE_KEY)) {
                msg.textContent = "You have already voted! Thank you.";
                msg.style.color = "#ff5555";
                return;
            }

            msg.textContent = "Submitting...";
            
            runTransaction(dbRef, (currentData) => {
                if (currentData === null) {
                    return { sum: rating, count: 1 };
                } else {
                    return {
                        sum: (currentData.sum || 0) + rating,
                        count: (currentData.count || 0) + 1
                    };
                }
            }).then(() => {
                msg.textContent = "Vote accepted! Thank you.";
                msg.style.color = "#55ff55";
                localStorage.setItem(LOCAL_STORAGE_KEY, 'true');
                stars.forEach((s, i) => {
                    if (i < rating) s.classList.add('active');
                });
            }).catch((err) => {
                console.error("Firebase Error:", err);
                msg.textContent = "Access error.";
                msg.style.color = "red";
            });
        }

        onValue(dbRef, (snapshot) => {
            const data = snapshot.val();
            if (data && data.count > 0) {
                const average = (data.sum / data.count).toFixed(1);
                avgDisplay.textContent = average;
                countDisplay.textContent = data.count;
            } else {
                avgDisplay.textContent = "0.0";
                countDisplay.textContent = "0";
            }
        }, (error) => {
            console.error("Firebase Read Error:", error);
            avgDisplay.textContent = "ERR"; 
            msg.textContent = "Database error.";
            msg.style.color = "red";
        });
    </script>
</body>
</html>
